{
  "name": "medi",
  "version": "0.1.0",
  "description": "Angular SSR application for medical administration workflows.",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "build:production": "ng build --configuration production",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "test:ci": "ng test --watch=false --browsers=ChromeHeadless",
    "audit:ci": "npm audit --omit=dev --audit-level=high",
    "serve:ssr:medi": "node dist/medi/server/server.mjs"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "20.3.26",
    "@angular/cdk": "20.2.14",
    "@angular/common": "20.3.26",
    "@angular/compiler": "20.3.26",
    "@angular/core": "20.3.26",
    "@angular/forms": "20.3.26",
    "@angular/material": "20.2.14",
    "@angular/platform-browser": "20.3.26",
    "@angular/platform-browser-dynamic": "20.3.26",
    "@angular/platform-server": "20.3.26",
    "@angular/router": "20.3.26",
    "@angular/ssr": "20.3.32",
    "bootstrap": "5.3.8",
    "express": "4.22.2",
    "rxjs": "~7.8.2",
    "tslib": "^2.8.1",
    "zone.js": "~0.15.1"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "20.3.26",
    "@angular/cli": "20.3.26",
    "@angular/compiler-cli": "20.3.26",
    "@types/express": "^4.17.23",
    "@types/jasmine": "~5.1.9",
    "@types/node": "^20.19.0",
    "jasmine-core": "~5.1.2",
    "karma": "~6.4.4",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.1",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "typescript": "~5.8.3"
  },
  "engines": {
    "node": ">=20.19 <23",
    "npm": ">=10"
  }
}
